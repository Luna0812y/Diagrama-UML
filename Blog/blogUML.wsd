@startuml
scale 2
left to right direction
skinparam PackageStyle rect
actor usuario
actor dono
rectangle Blog {
    custumer -- (Blog)
    (ler conteudo) -- usuario
    (criar blog) -- usuario
    (ler conteudo).> (comentar): include
    (remover comentario).> (ler conteudo): extend

    dono -- (criar blog)
    (criar nota) -- dono
    (remover nota).> (criar nota): extend
    (ler conteudo).> (remover nota): include
}
@enduml